# VibeFlow MCP Configuration
VIBEFLOW_MCP_URL=https://tool.vibeflow.ai/mcp
VIBEFLOW_API_KEY=your_vibeflow_api_key_here

# Server Configuration
NODE_ENV=production
PORT=3000

# Optional: Convex Configuration (if using Convex)
CONVEX_DEPLOYMENT=your_convex_deployment
CONVEX_URL=your_convex_url
CONVEX_SITE_URL=your_convex_site_url
MCP_AUTH_TOKEN=your_mcp_auth_token_here
